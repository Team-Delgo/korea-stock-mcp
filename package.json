{
  "name": "korea-stocks-mcp",
  "version": "0.1.0",
  "description": "Read-only KIS and DART MCP server skeleton for Kakao PlayMCP.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
